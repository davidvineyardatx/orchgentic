# Orchgentic environment variables

# Groq provider
GROQ_API_KEY=your_groq_api_key_here

# OpenAI provider, if used by an agent config
OPENAI_API_KEY=your_openai_api_key_here

# Optional local provider examples, for future/local development
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# OLLAMA_BASE_URL=http://localhost:11434

# Gmail OAuth setup uses a credentials JSON file and named connection:
# orch connect gmail --name assistant --credentials credentials.json
